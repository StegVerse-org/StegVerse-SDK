{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/stegmerch/drop_manifest.schema.json",
  "title": "StegMerch Drop Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "drop_id", "design_ref", "brand_authorization_ref", "location_authorization_ref", "opens_at", "closes_at", "currency", "unit_price_minor", "revenue_split", "status"],
  "properties": {
    "schema_version": {"const": "stegmerch.drop_manifest.v1"},
    "drop_id": {"type": "string", "pattern": "^drop_[a-z0-9._-]+$"},
    "design_ref": {"type": "string", "minLength": 1},
    "brand_authorization_ref": {"type": "string", "minLength": 1},
    "location_authorization_ref": {"type": "string", "minLength": 1},
    "opens_at": {"type": "string", "format": "date-time"},
    "closes_at": {"type": "string", "format": "date-time"},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "unit_price_minor": {"type": "integer", "minimum": 1},
    "revenue_split": {"type": "array", "minItems": 1},
    "status": {"enum": ["draft", "ready", "open", "closed", "cancelled"]}
  }
}
