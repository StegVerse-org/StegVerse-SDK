{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/stegmerch/brand_authorization_record.schema.json",
  "title": "StegMerch Brand Authorization Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authorization_id", "brand", "grantor", "grantee", "scope", "valid_from", "valid_until", "evidence_refs", "status"],
  "properties": {
    "schema_version": {"const": "stegmerch.brand_authorization_record.v1"},
    "authorization_id": {"type": "string", "pattern": "^brandauth_[a-z0-9._-]+$"},
    "brand": {"type": "string", "minLength": 1},
    "grantor": {"type": "string", "minLength": 1},
    "grantee": {"type": "string", "minLength": 1},
    "scope": {"type": "object"},
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_until": {"type": "string", "format": "date-time"},
    "evidence_refs": {"type": "array", "minItems": 1},
    "status": {"enum": ["pending", "active", "suspended", "revoked", "expired"]}
  }
}
