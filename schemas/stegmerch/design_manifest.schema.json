{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/stegmerch/design_manifest.schema.json",
  "title": "StegMerch Design Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "design_id", "brand_ref", "location_ref", "surfaces", "content_hash", "status"],
  "properties": {
    "schema_version": {"const": "stegmerch.design_manifest.v1"},
    "design_id": {"type": "string", "pattern": "^design_[a-z0-9._-]+$"},
    "brand_ref": {"type": "string", "minLength": 1},
    "location_ref": {"type": "string", "minLength": 1},
    "surfaces": {"type": "array", "minItems": 1},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "status": {"enum": ["draft", "authorized", "retired"]}
  }
}
