{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/session_usage_receipt.schema.json",
  "title": "SDK Session Usage Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_type", "session_id", "aggregation_sha256", "measurement_count_received", "measurement_count_unique", "entry_points", "transition_ids", "totals", "excluded", "dedupe_semantics", "source_event_hashes", "custody_posture", "authority_boundary", "receipt_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "receipt_type": {"const": "SDK_SESSION_USAGE_AGGREGATION"},
    "session_id": {"type": "string", "minLength": 1},
    "aggregation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "measurement_count_received": {"type": "integer", "minimum": 1},
    "measurement_count_unique": {"type": "integer", "minimum": 1},
    "entry_points": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "transition_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "totals": {"type": "array", "items": {"type": "object"}},
    "excluded": {"type": "array", "items": {"type": "object"}},
    "dedupe_semantics": {"const": "measurement_id_plus_metric_owner"},
    "source_event_hashes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "custody_posture": {"const": "HANDOFF_READY_NOT_CUSTODIED"},
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_is_execution_authority", "receipt_is_admissibility", "receipt_is_master_record_custody", "aggregation_is_universal_cost_claim"],
      "properties": {
        "receipt_is_execution_authority": {"const": false},
        "receipt_is_admissibility": {"const": false},
        "receipt_is_master_record_custody": {"const": false},
        "aggregation_is_universal_cost_claim": {"const": false}
      }
    },
    "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
