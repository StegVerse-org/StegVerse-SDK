{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/formal-testing-route.schema.json",
  "title": "StegVerse Formal Testing Route Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "ingestion_point",
    "dataset_manifest_hash",
    "intake_receipt_id",
    "declared_routes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "ingestion_point": {
      "type": "string",
      "const": "StegVerse-org/StegVerse-SDK"
    },
    "dataset_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "intake_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "intake_receipt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "declared_routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["route_id", "repository", "purpose"],
        "properties": {
          "route_id": {
            "type": "string",
            "enum": [
              "public_demo_validation",
              "formal_demo_runner",
              "rigorous_sandbox_testing",
              "standing_proof",
              "boundary_glm_case"
            ]
          },
          "repository": {
            "type": "string",
            "enum": [
              "StegVerse-org/stegverse-demo-suite",
              "StegVerse-org/demo-suite-runner",
              "StegGhost/entity-sandbox-runner",
              "StegVerse-Labs/Standing-Proof-Engine",
              "StegVerse-Labs/Boundary-Test"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "route_receipt_required": {
            "type": "boolean",
            "const": true
          }
        },
        "additionalProperties": false
      }
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
